{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/cyberuni/marketplace/main/schema/claude/marketplace.json",
  "title": "Claude Code Marketplace",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Unique slug for this marketplace",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pluginRoot": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "allowCrossMarketplaceDependenciesOn": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/plugin" }
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "skills": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "commands": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "agents": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "hooks": {
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "mcpServers": {
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "lspServers": {
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strict": { "type": "boolean" },
        "defaultEnabled": { "type": "boolean" },
        "category": {
          "type": "string"
        },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "author": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          }
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!.*\\.\\.).+$"
        },
        {
          "type": "object",
          "required": ["source", "url"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "url" },
            "url": { "type": "string", "format": "uri" },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
          }
        },
        {
          "type": "object",
          "required": ["source", "repo"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "github" },
            "repo": { "type": "string" },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
          }
        },
        {
          "type": "object",
          "required": ["source", "url", "path"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "git-subdir" },
            "url": { "type": "string", "format": "uri" },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
            "path": { "type": "string" },
            "minProperties": 3
          }
        },
        {
          "type": "object",
          "required": ["source", "package"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "npm" },
            "package": { "type": "string" },
            "version": { "type": "string" },
            "registry": { "type": "string", "format": "uri" }
          }
        }
      ]
    }
  }
}
